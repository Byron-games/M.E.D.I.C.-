{
  "title": "HealthNet - Service Overview",
  "uid": "healthnet-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "tags": ["healthnet"],
  "panels": [
    {
      "id": 1,
      "title": "Service Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "targets": [{
        "expr": "up",
        "legendFormat": "{{ job }}"
      }],
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["last"] }
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      }
    },
    {
      "id": 2,
      "title": "API Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [{
        "expr": "sum(rate(http_server_requests_seconds_count[1m])) by (job)",
        "legendFormat": "{{ job }}"
      }]
    },
    {
      "id": 3,
      "title": "API P95 Latency (seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket[5m])) by (job, le))",
        "legendFormat": "{{ job }}"
      }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [{
        "expr": "sum(rate(http_server_requests_seconds_count{status=~'5..'}[5m])) by (job) / sum(rate(http_server_requests_seconds_count[5m])) by (job) * 100",
        "legendFormat": "{{ job }}"
      }]
    },
    {
      "id": 5,
      "title": "JVM Heap Usage (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [{
        "expr": "jvm_memory_used_bytes{area='heap'} / jvm_memory_max_bytes{area='heap'} * 100",
        "legendFormat": "{{ job }}"
      }]
    },
    {
      "id": 6,
      "title": "Active DB Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [{
        "expr": "hikaricp_connections_active",
        "legendFormat": "{{ job }}"
      }]
    },
    {
      "id": 7,
      "title": "Outbreak Alerts (Last 7 Days)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [{
        "expr": "healthnet_outbreak_alert_count",
        "legendFormat": "Active Alerts"
      }],
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    }
  ]
}
